# Groq API Keys (required)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=your_groq_fallback_key_here

# Gemini API Keys (required for Stage 6 text generation)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_gemini_fallback_key_here

# Cerebras API Key (fallback LLM)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Search + Places
TAVILY_API_KEY=your_tavily_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# HuggingFace (required for logo generation)
HF_API_KEY=your_huggingface_api_key_here

# Optional overrides
DEFAULT_MAX_ITERATIONS=7